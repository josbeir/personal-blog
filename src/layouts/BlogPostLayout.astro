---
import BaseLayout from './BaseLayout.astro';
import GiscusComments from '../components/GiscusComments.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const date = post.data.date;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.image?.src}>
  <header class="mb-10 text-center">
    <h1 class="text-2xl md:text-3xl lg:text-4xl mb-10 font-extrabold max-w-4xl mx-auto leading-snug tracking-tight">
      {post.data.title}
    </h1>
    <div class="divider mb-10 mt-6">
      <time class="text-base-content/45" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
  </header>

  <article class="prose lg:prose-xl mx-auto">
    <Content />
  </article>

  <div class="mt-10 divider"></div>
  <section class="mt-8 xl:max-w-2/3 mx-auto">
    <GiscusComments />
  </section>
</BaseLayout>
