---
import { t } from '../i18n/index';
const locale = Astro.currentLocale ?? 'en';
---

<form action="https://formspree.io/f/mkndvanz" method="POST" class="block mx-auto bg-base-200 p-8 rounded-xl xl:max-w-2/3">
  <input type="text" name="_gotcha" style="display:none" />

  <fieldset class="fieldset">
    <legend class="fieldset-legend">{t(locale, 'form.email_label')}</legend>
    <input type="email" name="email" class="input input-lg w-full validator" placeholder={t(locale, 'form.email_placeholder')} required />
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">{t(locale, 'form.name_label')}</legend>
    <input type="text" name="name" class="input input-lg w-full validator" placeholder={t(locale, 'form.name_placeholder')} required />
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">{t(locale, 'form.company_label')}</legend>
    <input type="text" name="company" class="input input-lg w-full validator" placeholder={t(locale, 'form.company_placeholder')} required />
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">{t(locale, 'form.phone_label')}</legend>
    <input type="text" name="phone" class="input input-lg w-full validator" placeholder={t(locale, 'form.phone_placeholder')} required />
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">{t(locale, 'form.message_label')}</legend>
    <textarea name="message" placeholder={t(locale, 'form.message_placeholder')} class="textarea textarea-lg w-full validator" rows="5" required></textarea>
  </fieldset>

  <div class="mt-4">
    <button type="submit" class="btn btn-primary">{t(locale, 'form.submit')}</button>
  </div>
</form>
