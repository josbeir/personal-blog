---
import { t } from '../i18n/index';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;
const date = data.date;
const teaserImg = data.image;
const desc = data.description?.substring(0, 180) ?? '';
const locale = Astro.currentLocale!;
const postsPrefix = `/${locale}/posts/`;
---

<article class="card bg-base-300 border border-base-content/10 hover:border-primary/35 transition-all overflow-hidden h-full">
  {teaserImg && (
    <a href={`${postsPrefix}${post.slug}/`} class="block">
      <img
        loading="lazy"
        class="w-full aspect-video object-cover"
        src={teaserImg.src}
        alt={`${data.title} Teaser Image`}
      />
    </a>
  )}
  <div class="card-body">
    <div class="content flex-1">
      <h3 class="text-2xl leading-tight mb-2">
        <a class="hover:text-primary transition-colors" href={`${postsPrefix}${post.slug}/`}>{data.title}</a>
      </h3>
      <p class="text-sm text-base-content/60 mb-3">
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <p class="text-base-content/80">{desc}</p>
    </div>
    <div class="card-actions mt-4 justify-end">
      <a class="btn btn-outline btn-primary btn-md" href={`${postsPrefix}${post.slug}/`}>
        {t(Astro.currentLocale!, 'read_more')}
      </a>
    </div>
  </div>
</article>
